{
  "version": 2,
  "framework": null,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/(assets/.*)",
      "destination": "/dist/client/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/api/index"
    }
  ]
}
